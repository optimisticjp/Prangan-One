# ---------------------------------------------------------------
# Prangan One - environment variables
# The app runs 100% in the browser with localStorage until Supabase
# is connected. Nothing below is required for `npm run dev`.
# ---------------------------------------------------------------

# Demo mode: turns on the /demo page (role-picker shortcuts for resident/
# admin/accountant/owner, no password) and simulates the magic-link "email
# sent" state on the real /login screen when Supabase isn't configured.
# Defaults ON in local dev (import.meta.env.DEV) and OFF in a production
# build unless explicitly set to true here - a real production deployment
# for a paying society should never expose /demo. Set to true only for a
# sales-demo deployment kept separate from the real production one.
# VITE_DEMO_MODE=true

# Demo/sample data (Rajhans Tower + 2 lead societies). Defaults to on so
# `npm run dev` with no .env still shows a working demo. Set to false for
# a deployment that should start with no seed data, just a placeholder
# society until the owner creates a real one from /owner/societies/new.
# VITE_DEMO_SEED=false

# Supabase (Phase: backend hookup - see supabase/README.md)
# Region should be Mumbai if you want to honestly claim "data in India."
# VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# An online payment gateway and automated WhatsApp messaging are deferred,
# not part of the active build - see CLAUDE_CODE_NEXT_STEPS.md and
# README.md's Next steps section for what's actually active right now.
# Deliberately no variables listed here for either yet, so a future
# session doesn't get tempted to wire them prematurely. Manual payment
# recording and wa.me share links are the real, intended workflow for now.
