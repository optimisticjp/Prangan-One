# ---------------------------------------------------------------
# Prangan One - environment variables
# The app runs 100% in the browser with localStorage until Supabase
# is connected. Nothing below is required for `npm run dev`.
# ---------------------------------------------------------------

# Demo mode: shows the role-picker shortcuts (resident/admin/accountant/
# owner) on the login screen, and simulates the magic-link "email sent"
# state with no real backend. Defaults ON in local dev (import.meta.env.DEV)
# and OFF in a production build unless explicitly set to true here - a
# real production deployment for a paying society should never show these
# shortcuts. Set to true only for a sales-demo deployment kept separate
# from the real production one.
# VITE_DEMO_MODE=true

# Demo/sample data (Rajhans Tower + 2 lead societies). Defaults to on so
# `npm run dev` with no .env still shows a working demo. Set to false for
# a deployment that should start with no seed data, just a placeholder
# society until the owner creates a real one from /owner/societies/new.
# VITE_DEMO_SEED=false

# Supabase (Phase: backend hookup - see supabase/README.md)
# Region should be Mumbai if you want to honestly claim "data in India."
# VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# ---------------------------------------------------------------
# Deferred, not part of the current build. Listed here only so they're
# not a surprise later - do not add these until the corresponding
# feature is actually being built (see CLAUDE_CODE_NEXT_STEPS.md).
# ---------------------------------------------------------------

# Razorpay (deferred: online payments. Not needed to launch - manual UPI/
# bank/cash/cheque recording, confirmed by the committee, is the real
# payment flow in this build. Keep keys server-side, never in client env.)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# WhatsApp Cloud API (deferred: automated reminders, needs a verified Meta
# Business account. wa.me share links already work today for free.)
# WHATSAPP_TOKEN=
