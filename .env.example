# ---------------------------------------------------------------
# Prangan One - environment variables
# The app runs 100% in the browser with localStorage until Supabase
# is connected. Nothing below is required for `npm run dev`.
# ---------------------------------------------------------------

# Demo/sample data (Rajhans Tower + 2 lead societies). Defaults to on so
# `npm run dev` with no .env still shows a working demo. Set to false for
# a deployment that should start with no seed data, just a placeholder
# society until the owner creates a real one from /saas/new.
# VITE_DEMO_SEED=false

# Supabase (Phase: backend hookup - see supabase/README.md)
# Region should be Mumbai if you want to honestly claim "data in India."
# VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Razorpay (Phase: online payments - keep keys server-side, never in client env)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

# WhatsApp Cloud API (Phase: automated reminders, needs a verified Meta Business account)
# WHATSAPP_TOKEN=
